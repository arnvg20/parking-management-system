# Website bind address. Use 0.0.0.0 on AWS so the page is reachable externally.
HOST=0.0.0.0
PORT=5000

# Internal MediaMTX WHEP HTTP endpoint used by the backend proxy.
# If MediaMTX runs on the same EC2 instance, keep this as 127.0.0.1.
MEDIA_MTX_BASE_URL=http://127.0.0.1:8889

# MediaMTX stream path. The Jetson now publishes live video directly to MediaMTX
# on a path such as rtmp://YOUR_MEDIAMTX_HOST:1935/jetson-01.
MEDIA_MTX_STREAM_PATH=jetson-01

# Device ID used by the website-side command queue and status panel.
DEFAULT_DEVICE_ID=jetson-01

# Jetson API auth token for:
# /api/jetson/register
# /api/jetson/heartbeat
# /api/jetson/commands/next
# /api/jetson/commands/<id>/ack
# /api/jetson/telemetry
# /api/jetson/upload-image
JETSON_API_TOKEN=dev-jetson-token

# Browser telemetry reads from /ws/telemetry.
# Your upstream telemetry producer should POST to /api/telemetry with this key.
TELEMETRY_API_KEY=dev-telemetry-token

# Optional demo-only fake telemetry source for easy local or AWS demos.
DEMO_TELEMETRY_ENABLED=false
DEMO_TELEMETRY_INTERVAL_SECONDS=1.5

# Optional timeout for backend-to-MediaMTX signaling requests.
MEDIA_MTX_REQUEST_TIMEOUT_SECONDS=10

# Do not put the public EC2 IP or domain in MEDIA_MTX_BASE_URL unless MediaMTX is remote.
# The public AWS IP or domain belongs in mediamtx.sample.yml under webrtcAdditionalHosts.
